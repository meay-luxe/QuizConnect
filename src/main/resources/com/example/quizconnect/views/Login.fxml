<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<StackPane
        fx:id="rootPane"
        prefHeight="660.0"
        prefWidth="1213.0"
        styleClass="root-pane"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.quizconnect.controllers.LoginController">

    <VBox
            alignment="TOP_CENTER"
            styleClass="main-container"
            StackPane.alignment="TOP_CENTER">
        <padding>
            <Insets top="60.0" bottom="40.0"/>
        </padding>

        <!-- ══════ APP HEADER ══════ -->
        <VBox alignment="CENTER" spacing="6.0" styleClass="header-box">
            <padding>
                <Insets bottom="24.0"/>
            </padding>
            <Text styleClass="app-title" text="QuizConnect"/>
            <Text styleClass="app-subtitle" text="Learn Together, Live"/>
        </VBox>

        <!-- ══════ GLASSMORPHIC CARD ══════ -->
        <VBox
                fx:id="cardBox"
                alignment="TOP_CENTER"
                styleClass="card"
                spacing="0">

            <!-- —— Tab Toggle —— -->
            <HBox
                    fx:id="toggleBox"
                    alignment="CENTER"
                    styleClass="toggle-box"
                    maxWidth="Infinity">
                <Button
                        fx:id="loginTabBtn"
                        text="Login"
                        onAction="#handleShowLogin"
                        styleClass="tab-btn,tab-active"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"/>
                <Button
                        fx:id="registerTabBtn"
                        text="Register"
                        onAction="#handleShowRegister"
                        styleClass="tab-btn"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Spacer between toggle and form -->
            <Region prefHeight="20.0"/>

            <!-- ══════ FORM AREA ══════ -->
            <VBox fx:id="formBox" styleClass="form-box" spacing="14.0">

                <!-- Username (always visible) -->
                <VBox spacing="6.0">
                    <Label styleClass="field-label" text="Username"/>
                    <TextField
                            fx:id="usernameField"
                            promptText="Enter your username"
                            maxWidth="Infinity"
                            styleClass="input-field"/>
                </VBox>

                <!-- Email — register only, hidden by default -->
                <VBox
                        fx:id="emailGroup"
                        spacing="6.0"
                        visible="false"
                        managed="false">
                    <Label styleClass="field-label" text="Email"/>
                    <TextField
                            fx:id="emailField"
                            promptText="Enter your email"
                            maxWidth="Infinity"
                            styleClass="input-field"/>
                </VBox>

                <!-- Password (always visible) -->
                <VBox spacing="6.0">
                    <Label styleClass="field-label" text="Password"/>
                    <PasswordField
                            fx:id="passwordField"
                            promptText="Enter your password"
                            maxWidth="Infinity"
                            styleClass="input-field"/>
                </VBox>

                <!-- Confirm Password — register only, hidden by default -->
                <VBox
                        fx:id="confirmPasswordGroup"
                        spacing="6.0"
                        visible="false"
                        managed="false">
                    <Label styleClass="field-label" text="Confirm Password"/>
                    <PasswordField
                            fx:id="confirmPasswordField"
                            promptText="Re-enter your password"
                            maxWidth="Infinity"
                            styleClass="input-field"/>
                </VBox>

                <!-- Role Selector (always visible) -->
                <VBox spacing="8.0">
                    <Label styleClass="field-label" text="I am a..."/>
                    <HBox fx:id="roleBox" alignment="CENTER" spacing="12.0">
                        <ToggleButton
                                fx:id="studentBtn"
                                text="Student"
                                selected="true"
                                styleClass="role-btn,role-selected"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS"/>
                        <ToggleButton
                                fx:id="teacherBtn"
                                text="Teacher"
                                styleClass="role-btn"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Error label — hidden until needed -->
                <Label
                        fx:id="errorLabel"
                        styleClass="error-text"
                        text=""
                        wrapText="true"
                        visible="false"
                        managed="false"
                        maxWidth="Infinity"/>

                <!-- Submit Button -->
                <Button
                        fx:id="submitBtn"
                        text="Sign In"
                        onAction="#handleSubmit"
                        maxWidth="Infinity"
                        styleClass="submit-btn"/>

            </VBox>
        </VBox>
    </VBox>
</StackPane>